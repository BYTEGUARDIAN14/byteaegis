# ── Dependencies ──────────────────────────────────────────
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# ── Next.js build output ──────────────────────────────────
/.next/
/out/
/build

# ── Environment & secrets — never commit these ─────────────
.env
.env.*
!.env.example       # allow a safe example file
*.pem
*.key
*.cert
secrets/

# ── Debug / log files ────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── Vercel ───────────────────────────────────────────────
.vercel

# ── TypeScript cache ──────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Python ───────────────────────────────────────────────
/.venv/
__pycache__/

# ── OS artefacts ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor config ────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ── Misc ─────────────────────────────────────────────────
.cache
tsc_output.txt